{
  "name": "omahi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @omahi/extension dev",
    "build": "pnpm --filter @omahi/extension build",
    "dev:landing": "pnpm --filter @omahi/landing dev",
    "build:landing": "pnpm --filter @omahi/landing build",
    "test": "pnpm -r --if-present test",
    "e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p e2e --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "packageManager": "pnpm@10.6.2"
}
